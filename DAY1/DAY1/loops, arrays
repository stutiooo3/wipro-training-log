// Object
let person = {
    name: "Alice",
    age: 30,
    city: "New York"
};

console.log("Object:", person);
console.log("Name:", person.name);
console.log("Age:", person.age);
console.log("City:", person.city);

// Dynamic typing
let value = "Aryan";
let number = 5;
let flag = true;

value = 23;
console.log("value:", value);

// Function
function addNumbers(num1, num2) {
    return num1 + num2;
}

console.log("Function addNumbers(5, 10):", addNumbers(5, 10));

// const example
const constantValue = 5;
console.log(constantValue);

// let vs var
let outerLet = 5;
var outerVar = 6;

{
    let innerLet = 10;   // block scoped
    var innerVar = 20;   // function scoped

    console.log("Inside block, innerLet:", innerLet);
    console.log("Inside block, innerVar:", innerVar);
}

console.log("Outside block, outerLet:", outerLet);
console.log("Outside block, outerVar:", outerVar);

// Arrays
let mixedArray = [1, "Aaryan", 3, true, 5];
let numberArray = [1, 2, 3, 4, 5];

// Condition
let firstNum = 0;
let secondNum = 10;

if (firstNum > secondNum) {
    console.log("firstNum is greater");
} else {
    console.log("secondNum is greater");
}

// Switch
let choice = "a";

switch (choice.toUpperCase()) {
    case "A":
        console.log("Choice is A");
        break;
    case "B":
        console.log("Choice is B");
        break;
    default:
        console.log("Invalid choice");
}